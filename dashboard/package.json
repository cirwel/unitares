{
  "name": "unitares-dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "UNITARES governance dashboard. Vite build + vitest coverage of the render logic.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src tests *.config.js eslint.config.mjs",
    "format:check": "prettier --check src tests *.config.js eslint.config.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.8.4",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.6.0"
  }
}
