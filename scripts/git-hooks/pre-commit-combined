#!/bin/bash
# Combined pre-commit hook: markdown policy + version sync
# Install: make install-hooks

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

echo "🔍 Pre-commit checks..."

# HARD LIMIT: Total tracked markdown files.
# Uses git ls-files so worktrees, caches, and gitignored dirs are
# automatically excluded — no brittle find-exclusion list needed.
MAX_MARKDOWN_FILES=999
TOTAL_MD=$(git ls-files '*.md' | wc -l | tr -d ' ')

if [ "$TOTAL_MD" -gt "$MAX_MARKDOWN_FILES" ]; then
    echo ""
    echo "❌ MARKDOWN PROLIFERATION BLOCKED!"
    echo "   Total: $TOTAL_MD files (max: $MAX_MARKDOWN_FILES)"
    echo ""
    echo "   Run: python3 scripts/audit_markdown_proliferation.py --stats"
    echo "   Then consolidate or delete before committing."
    exit 1
fi

echo "📄 Markdown count: $TOTAL_MD / $MAX_MARKDOWN_FILES"

# Check for new markdown files
NEW_MARKDOWN_FILES=$(git diff --cached --name-only --diff-filter=A | grep '\.md$' || true)

if [ -n "$NEW_MARKDOWN_FILES" ]; then
    echo ""
    echo "📄 Checking new markdown files..."

    VIOLATIONS=0

    for file in $NEW_MARKDOWN_FILES; do
        # Skip approved files and directories
        if [[ "$file" == "README.md" ]] || \
           [[ "$file" == "CLAUDE.md" ]] || \
           [[ "$file" == "AGENTS.md" ]] || \
           [[ "$file" == "CHANGELOG.md" ]] || \
           [[ "$file" == "START_HERE.md" ]] || \
           [[ "$file" == "CODEX_START.md" ]] || \
           [[ "$file" == "docs/CHANGELOG.md" ]] || \
           [[ "$file" == "docs/README.md" ]] || \
           [[ "$file" == "docs/QUICK_REFERENCE.md" ]] || \
           [[ "$file" == "docs/DOC_MAP.md" ]] || \
           [[ "$file" == docs/MARKDOWN_*.md ]] || \
           [[ "$file" == docs/guides/*.md ]] || \
           [[ "$file" == docs/architecture/*.md ]] || \
           [[ "$file" == docs/specs/*.md ]] || \
           [[ "$file" == docs/plans/*.md ]] || \
           [[ "$file" == docs/handoffs/*.md ]] || \
           [[ "$file" == docs/operations/*.md ]] || \
           [[ "$file" == */archive/* ]] || \
           [[ "$file" == .agent-guides/* ]] || \
           [[ "$file" == scripts/age/*.md ]] || \
           [[ "$file" == specs/*.md ]] || \
           [[ "$file" == commands/*.md ]] || \
           [[ "$file" == skills/*/SKILL.md ]] || \
           [[ "$file" == agents/*.md ]]; then
            echo "  ✅ $file - Approved"
            continue
        fi

        # Check file size
        if [ -f "$file" ]; then
            WORD_COUNT=$(wc -w < "$file" 2>/dev/null || echo "0")

            if [ "$WORD_COUNT" -lt 150 ]; then
                echo "  ❌ $file - Too small ($WORD_COUNT words, need 150+)"
                echo "     → Below 150 words is recap/summary territory — consolidate into an existing doc or use store_knowledge() instead"
                VIOLATIONS=$((VIOLATIONS + 1))
            elif [ "$WORD_COUNT" -lt 500 ]; then
                echo "  ⚠️  $file - Small ($WORD_COUNT words, recommend 500+)"
                echo "     → Deliberate specialized references are fine; verify this isn't per-turn slop"
            elif [ "$WORD_COUNT" -lt 1000 ]; then
                echo "  ⚠️  $file - Moderate ($WORD_COUNT words, recommend 1000+)"
                echo "     → Consider consolidating into existing doc if scope overlaps"
            else
                echo "  ✅ $file - Size OK ($WORD_COUNT words)"
            fi
        fi
    done

    if [ $VIOLATIONS -gt 0 ]; then
        echo ""
        echo "❌ Markdown placement heuristic violation!"
        echo ""
        echo "   Options:"
        echo "   1. Consolidate into existing doc"
        echo "   2. Use store_knowledge() for insights/discoveries"
        echo "   3. Archive if historical"
        echo "   4. Skip check: git commit --no-verify (not recommended)"
        exit 1
    fi
fi

# Validate markdown formatting (warn-only)
if command -v python3 &> /dev/null; then
    if [ -f "$PROJECT_ROOT/scripts/validate_markdown_formatting.py" ]; then
        echo ""
        echo "📝 Validating markdown formatting..."
        python3 "$PROJECT_ROOT/scripts/validate_markdown_formatting.py" || {
            echo ""
            echo "⚠️  Markdown formatting issues found"
            echo "   Run: python3 scripts/validate_markdown_formatting.py --fix"
            echo "   Or: git commit --no-verify (not recommended)"
            # Don't fail commit for formatting issues (warn only)
        }
    fi
fi

# Version sync check: fire when VERSION or pyproject.toml is staged.
if git diff --cached --name-only | grep -qE '^(VERSION|pyproject\.toml)$'; then
    echo ""
    echo "🔢 Version-tracked file changed — checking sync..."
    python3 "$PROJECT_ROOT/scripts/ops/version_manager.py" --check || {
        echo ""
        echo "❌ Version mismatch! Run: make version-bump PART=minor"
        echo "   Or: python3 scripts/ops/version_manager.py --update"
        exit 1
    }
fi

echo ""
echo "✅ Pre-commit checks passed"
