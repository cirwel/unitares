#!/usr/bin/env bash
# UNITARES CLI — thin REST wrapper for the governance MCP server.
# Usage: unitares <command> [args...]
#
# Environment:
#   UNITARES_URL          Base URL (default: http://localhost:8767). A trailing
#                         "/" or "/mcp" or "/mcp/" is stripped automatically so
#                         accidental MCP-path suffixes don't break REST calls.
#   UNITARES_AGENT        Stable agent name for X-Agent-Id (default:
#                         cli-<shorthost>-<user>). Identity is bound to this.
#   UNITARES_TOKEN        Optional bearer token; sent as Authorization header.
#   UNITARES_SESSION_FILE Path to the local session JSON (default:
#                         ~/.unitares_session.json). Onboard uses cached
#                         uuid only as parent_agent_id lineage.

set -u
set -o pipefail

# --- config ------------------------------------------------------------------

_raw_url="${UNITARES_URL:-http://localhost:8767}"
# Strip trailing slash, then any trailing /mcp (common mistake when pasting
# the streamable-http URL into UNITARES_URL).
_raw_url="${_raw_url%/}"
_raw_url="${_raw_url%/mcp}"
_raw_url="${_raw_url%/}"
UNITARES_URL="$_raw_url"

SESSION_FILE="${UNITARES_SESSION_FILE:-${HOME}/.unitares_session.json}"

_default_agent="cli-$(hostname -s 2>/dev/null || echo host)-${USER:-user}"
AGENT_ID="${UNITARES_AGENT:-$_default_agent}"

TIMEOUT="${UNITARES_TIMEOUT:-15}"

# --- session store -----------------------------------------------------------

_py_read_field() {
    local field="$1"
    [ -f "$SESSION_FILE" ] || return 0
    SESSION_FILE="$SESSION_FILE" FIELD="$field" python3 -c '
import json, os, sys
try:
    with open(os.environ["SESSION_FILE"]) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)
value = data.get(os.environ["FIELD"])
if value is not None:
    print(value)
' 2>/dev/null
}

_py_write_session() {
    SESSION_FILE="$SESSION_FILE" AGENT_ID="$AGENT_ID" CSID="${1:-}" CTOKEN="${2:-}" UUID="${3:-}" PARENT="${4:-}" python3 -c '
import json, os
payload = {"agent_id": os.environ["AGENT_ID"]}
sid = os.environ.get("CSID") or ""
token = os.environ.get("CTOKEN") or ""
uuid = os.environ.get("UUID") or ""
parent = os.environ.get("PARENT") or ""
if uuid:
    payload["uuid"] = uuid
if sid:
    payload["client_session_id"] = sid
if token:
    payload["continuity_token"] = token
if parent:
    payload["parent_agent_id"] = parent
    payload["spawn_reason"] = "new_session"
with open(os.environ["SESSION_FILE"], "w") as f:
    json.dump(payload, f, indent=2)
'
}

STORED_UUID="$(_py_read_field uuid || true)"
STORED_SESSION_ID="$(_py_read_field client_session_id || true)"
SESSION_ID="$STORED_SESSION_ID"
CONT_TOKEN="$(_py_read_field continuity_token || true)"

# --- HTTP --------------------------------------------------------------------

_base_headers=(
    -H "Content-Type: application/json"
    -H "X-Agent-Id: ${AGENT_ID}"
)
[ -n "${UNITARES_TOKEN:-}" ] && _base_headers+=( -H "Authorization: Bearer ${UNITARES_TOKEN}" )

_curl_fetch() {
    # _curl_fetch <method> <path> [post-body] [include-session-header]
    # Prints body on 2xx, emits error + returns 1 on any other HTTP status,
    # and returns 2 on network failure.
    local method="$1" path="$2" body="${3:-}" include_session="${4:-1}"
    local tmp code curl_rc
    local headers=("${_base_headers[@]}")
    if [ "$include_session" = "1" ] && [ -n "${SESSION_ID:-}" ]; then
        headers+=( -H "X-Session-ID: ${SESSION_ID}" )
    fi
    tmp=$(mktemp -t unitares_cli_XXXXXX)
    if [ "$method" = "POST" ]; then
        code=$(curl -s --max-time "$TIMEOUT" "${headers[@]}" \
            -X POST -d "$body" \
            -o "$tmp" -w "%{http_code}" "${UNITARES_URL}${path}")
        curl_rc=$?
    else
        code=$(curl -s --max-time "$TIMEOUT" "${headers[@]}" \
            -o "$tmp" -w "%{http_code}" "${UNITARES_URL}${path}")
        curl_rc=$?
    fi
    if [ $curl_rc -ne 0 ] || [ "$code" = "000" ]; then
        echo "error: could not reach ${UNITARES_URL}${path} (curl exit ${curl_rc}, http ${code})" >&2
        echo "hint: run 'unitares diag' to check reachability; UNITARES_URL=${UNITARES_URL}" >&2
        rm -f "$tmp"
        return 2
    fi
    if [ "${code:0:1}" != "2" ]; then
        echo "error: HTTP ${code} from ${UNITARES_URL}${path}" >&2
        if [ "${UNITARES_DEBUG:-0}" = "1" ]; then
            echo "--- response body ---" >&2
            head -c 2000 "$tmp" >&2
            echo >&2
        else
            echo "hint: set UNITARES_DEBUG=1 to see response body; check UNITARES_URL." >&2
        fi
        rm -f "$tmp"
        return 1
    fi
    cat "$tmp"
    rm -f "$tmp"
}

_curl_get() {
    _curl_fetch GET "$1"
}

_curl_post_tool() {
    local tool="$1" args="${2:-{\}}"
    # Inject known in-session transport continuity for ordinary calls, but
    # never onto force_new startup onboards. continuity_token is deliberately
    # not auto-injected; it is only for explicit PATH 0 ownership rebinds.
    local payload include_session
    payload=$(TOOL="$tool" RAW_ARGS="$args" CSID="${SESSION_ID:-}" python3 -c '
import json, os, sys
tool = os.environ["TOOL"]
raw_args = os.environ.get("RAW_ARGS") or "{}"
sid = os.environ.get("CSID") or ""
try:
    args = json.loads(raw_args) if raw_args else {}
except json.JSONDecodeError as exc:
    sys.stderr.write(f"error: invalid JSON for arguments: {exc}\n")
    sys.exit(2)
if not isinstance(args, dict):
    sys.stderr.write("error: arguments must be a JSON object\n")
    sys.exit(2)
inject = not bool(args.get("force_new"))
if inject and sid:
    args.setdefault("client_session_id", sid)
print(json.dumps({"name": tool, "arguments": args}))
') || return $?
    include_session=$(RAW_ARGS="$args" python3 -c '
import json, os
try:
    args = json.loads(os.environ.get("RAW_ARGS") or "{}")
except Exception:
    args = {}
print("0" if isinstance(args, dict) and bool(args.get("force_new")) else "1")
')
    _curl_fetch POST "/v1/tools/call" "$payload" "$include_session"
}

_check_body() {
    local body="$1" what="$2"
    if [ -z "$body" ]; then
        echo "error: empty response from ${UNITARES_URL} (${what})" >&2
        echo "hint: check 'unitares diag' — the server may be unreachable or the URL has a stale path." >&2
        return 1
    fi
    printf '%s' "$body"
}

# --- pretty-printers ---------------------------------------------------------

_pretty_json() {
    python3 -c "import json,sys; print(json.dumps(json.loads(sys.stdin.read()), indent=2))" 2>/dev/null || cat
}

parse_health() {
    local body; body=$(cat)
    BODY="$body" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["BODY"])
except Exception as exc:
    print("error: bad JSON from /health: " + str(exc), file=sys.stderr)
    sys.exit(1)
print("Status:  " + str(data.get("status", "?")))
print("Version: " + str(data.get("version", "?")))
uptime = data.get("uptime") or {}
print("Uptime:  " + str(uptime.get("formatted", "?")))
db = data.get("database") or {}
print("DB:      " + str(db.get("status", "?")) + " (pool " + str(db.get("pool_size", "?")) + "/" + str(db.get("pool_max", "?")) + ")")
'
}

parse_onboard() {
    local body; body=$(cat)
    BODY="$body" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["BODY"])
except Exception as exc:
    print("error: bad JSON from onboard: " + str(exc), file=sys.stderr)
    sys.exit(1)
r = data.get("result") or {}
# Fail on both outer envelope (data.success) and the tool-level success
# field (r.success) — when an existing identity has an established
# trajectory the outer envelope is still true but r.success is false
# with a recovery hint.
if data.get("success") is False or not r or r.get("success") is False:
    msg = r.get("error") or data.get("error") or "onboard failed"
    print("error: " + str(msg), file=sys.stderr)
    recovery = r.get("recovery") or {}
    hint = recovery.get("hint") if isinstance(recovery, dict) else None
    if hint:
        print("hint: " + str(hint), file=sys.stderr)
    sys.exit(1)
welcome = (r.get("welcome") or r.get("message") or "onboarded").strip()
print("Welcome: " + welcome[:200])
print("Agent:   " + str(r.get("display_name") or r.get("agent_id") or "?"))
print("UUID:    " + str(r.get("uuid", "?")))
'
}

parse_update() {
    local body; body=$(cat)
    BODY="$body" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["BODY"])
except Exception as exc:
    print("error: bad JSON from process_agent_update: " + str(exc), file=sys.stderr)
    sys.exit(1)
r = data.get("result") or {}

def unwrap_update_payload(payload):
    current = payload
    for _ in range(2):
        if not isinstance(current, dict):
            return payload
        nested = current.get("result")
        has_update_fields = any(
            key in current for key in ("action", "verdict", "decision", "status", "metrics", "mirror", "margin")
        )
        if isinstance(nested, dict) and not has_update_fields:
            current = nested
            continue
        return current
    return current

r = unwrap_update_payload(r)
if data.get("success") is False or not r or r.get("success") is False:
    msg = data.get("error") or r.get("error") or "update failed"
    print("error: " + str(msg), file=sys.stderr)
    recovery = r.get("recovery") or {}
    hint = recovery.get("hint") if isinstance(recovery, dict) else None
    if hint:
        print("hint: " + str(hint), file=sys.stderr)
    sys.exit(1)
decision = r.get("decision") if isinstance(r.get("decision"), dict) else {}
metrics = r.get("metrics") if isinstance(r.get("metrics"), dict) else {}
verdict = (
    r.get("action")
    or decision.get("action")
    or r.get("verdict")
    or metrics.get("verdict")
    or r.get("status")
    or "?"
)
print("Verdict: " + str(verdict))
margin = r.get("margin")
if margin is None:
    margin = decision.get("margin")
if margin is not None:
    print("Margin:  " + str(margin))
mirror = r.get("mirror") or []
for line in mirror[:3]:
    print("  - " + str(line))
ia = r.get("identity_assurance") or {}
if ia:
    print("Identity: " + str(ia.get("tier", "?")) + " (" + str(ia.get("session_source", "?")) + ")")
'
}

parse_metrics() {
    local body; body=$(cat)
    BODY="$body" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["BODY"])
except Exception as exc:
    print("error: bad JSON from get_governance_metrics: " + str(exc), file=sys.stderr)
    sys.exit(1)
r = data.get("result") or {}
if not r:
    print("error: empty metrics response", file=sys.stderr)
    sys.exit(1)
def v(x):
    return x.get("value", x) if isinstance(x, dict) else x
def f(x):
    try:
        return format(float(x), ".2f")
    except Exception:
        return str(x)
E = v(r.get("E", 0))
I = v(r.get("I", 0))
S = v(r.get("S", 0))
V = v(r.get("V", 0))
print("Agent:   " + str(r.get("display_name") or r.get("agent_id", "?")))
print("Status:  " + str(r.get("status", "?")))
print("EISV:    E=" + f(E) + " I=" + f(I) + " S=" + f(S) + " V=" + f(V))
print("Summary: " + str(r.get("summary", "?")))
'
}

parse_tools() {
    local body; body=$(cat)
    BODY="$body" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["BODY"])
except Exception as exc:
    print("error: bad JSON from /v1/tools: " + str(exc), file=sys.stderr)
    sys.exit(1)
tools = data.get("tools") or []
count = data.get("count") or len(tools)
total = data.get("total_available", "?")
mode = data.get("mode", "?")
print("Tools: " + str(count) + "/" + str(total) + " (" + str(mode) + " mode)")
def tool_name_desc(tool):
    if not isinstance(tool, dict):
        return str(tool), ""
    # OpenAI-style: {"type":"function","function":{"name":...,"description":...}}
    fn = tool.get("function")
    if isinstance(fn, dict):
        return str(fn.get("name", "?")), str(fn.get("description", ""))
    # Fallback: flat shape
    return str(tool.get("name", "?")), str(tool.get("description") or tool.get("hint") or "")
for tool in tools[:20]:
    name, desc = tool_name_desc(tool)
    first_line = desc.split(".")[0][:60]
    print("  " + name.ljust(32) + " " + first_line)
more = len(tools) - 20
if more > 0:
    print("  ... +" + str(more) + " more")
'
}

# --- commands ----------------------------------------------------------------

cmd_diag() {
    echo "UNITARES_URL    : ${UNITARES_URL}"
    echo "UNITARES_AGENT  : ${AGENT_ID}"
    echo "SESSION_FILE    : ${SESSION_FILE}"
    echo "UUID            : ${STORED_UUID:-<none>}"
    echo "SESSION_ID      : ${SESSION_ID:-<none>}"
    [ -n "${CONT_TOKEN:-}" ] && echo "CONTINUITY      : present (len=${#CONT_TOKEN})" || echo "CONTINUITY      : <none>"
    echo
    echo -n "Reachability    : "
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "${UNITARES_URL}/health" || echo "000")
    if [ "$code" = "200" ]; then
        echo "OK (${code})"
    else
        echo "FAIL (${code})"
        return 1
    fi
}

cmd_onboard() {
    local name="${1:-$AGENT_ID}" purpose="${2:-}" force="${3:-}"
    local args
    args=$(NAME="$name" PURPOSE="$purpose" FORCE="$force" PARENT_UUID="${STORED_UUID:-}" python3 -c '
import json, os
args = {"name": os.environ["NAME"], "force_new": True}
purpose = os.environ.get("PURPOSE") or ""
if purpose:
    args["purpose"] = purpose
force = (os.environ.get("FORCE") or "").lower()
if force not in ("1", "true", "force", "yes", "--force"):
    parent = os.environ.get("PARENT_UUID") or ""
    if parent:
        args["parent_agent_id"] = parent
        args["spawn_reason"] = "new_session"
print(json.dumps(args))
')
    local body
    body=$(_curl_post_tool "onboard" "$args") || return 1
    _check_body "$body" "onboard" >/dev/null || return 1

    # Check tool-level success BEFORE writing the session file. If the
    # server returned result.success:false (e.g. trajectory_required), we
    # must not clobber any existing continuity material.
    local tool_ok
    tool_ok=$(BODY="$body" python3 -c '
import json, os
try:
    data = json.loads(os.environ["BODY"])
    r = data.get("result") or {}
    if data.get("success") is False:
        print("no"); exit()
    if r.get("success") is False:
        print("no"); exit()
    if not r:
        print("no"); exit()
    print("yes")
except Exception:
    print("no")
')
    if [ "$tool_ok" != "yes" ]; then
        printf '%s' "$body" | parse_onboard
        return 1
    fi

    # Extract session + continuity token + uuid in a single python invocation.
    local extracted sid token token_uuid uuid parent
    extracted=$(BODY="$body" python3 -c '
import json, os
try:
    data = json.loads(os.environ["BODY"])
    r = data.get("result") or {}
    print((r.get("client_session_id") or "") + "\t" + (r.get("continuity_token") or "") + "\t" + (r.get("uuid") or ""))
except Exception:
    print("\t\t")
')
    sid="${extracted%%	*}"
    token_uuid="${extracted#*	}"
    token="${token_uuid%%	*}"
    uuid="${token_uuid#*	}"
    parent=$(ARGS="$args" python3 -c '
import json, os
try:
    args = json.loads(os.environ["ARGS"])
    print(args.get("parent_agent_id") or "")
except Exception:
    print("")
')
    _py_write_session "$sid" "$token" "$uuid" "$parent"
    printf '%s' "$body" | parse_onboard
    echo "Session: ${sid:-<none>}"
}

cmd_update() {
    local text="${1:-Update}" complexity="${2:-0.5}" confidence="${3:-0.6}"
    local args
    args=$(TEXT="$text" COMPLEXITY="$complexity" CONFIDENCE="$confidence" python3 -c '
import json, os, sys
try:
    complexity = float(os.environ.get("COMPLEXITY") or 0.5)
    confidence = float(os.environ.get("CONFIDENCE") or 0.6)
except ValueError as exc:
    sys.stderr.write("error: complexity/confidence must be numeric: " + str(exc) + "\n")
    sys.exit(2)
print(json.dumps({
    "response_text": os.environ.get("TEXT") or "",
    "complexity": complexity,
    "confidence": confidence,
}))
') || return 1
    local body
    body=$(_curl_post_tool "process_agent_update" "$args") || return 1
    _check_body "$body" "process_agent_update" >/dev/null || return 1
    printf '%s' "$body" | parse_update
}

cmd_metrics() {
    local body
    body=$(_curl_post_tool "get_governance_metrics" "{}") || return 1
    _check_body "$body" "get_governance_metrics" >/dev/null || return 1
    printf '%s' "$body" | parse_metrics
}

cmd_health() {
    local body
    body=$(_curl_get "/health") || return 1
    _check_body "$body" "/health" >/dev/null || return 1
    printf '%s' "$body" | parse_health
}

cmd_tools() {
    local body
    body=$(_curl_get "/v1/tools") || return 1
    _check_body "$body" "/v1/tools" >/dev/null || return 1
    printf '%s' "$body" | parse_tools
}

cmd_call() {
    local tool="${1:-}" args="${2:-{\}}"
    if [ -z "$tool" ]; then
        echo "usage: unitares call <tool_name> [args_json]" >&2
        return 2
    fi
    local body
    body=$(_curl_post_tool "$tool" "$args") || return 1
    _check_body "$body" "tool:$tool" >/dev/null || return 1
    printf '%s' "$body" | _pretty_json
}

cmd_session() {
    echo "Agent ID:     ${AGENT_ID}"
    echo "Session file: ${SESSION_FILE}"
    echo "UUID:         ${STORED_UUID:-<none>}"
    echo "Session ID:   ${SESSION_ID:-<none>}"
    [ -n "${CONT_TOKEN:-}" ] && echo "Continuity:   present" || echo "Continuity:   <none>"
    echo "URL:          ${UNITARES_URL}"
}

cmd_reset() {
    rm -f "$SESSION_FILE"
    echo "Session reset. Next onboard will create a fresh identity for agent '${AGENT_ID}'."
}

cmd_help() {
    cat <<'EOF'
UNITARES CLI — REST wrapper for the governance MCP server

Commands:
  onboard [name] [purpose] [force]  Onboard a fresh identity; cached uuid is
                                    declared as parent_agent_id unless "force"
                                    is passed as 3rd arg
  update "text" [complexity] [confidence]
                                    Post a governance check-in (defaults: 0.5 / 0.6)
  metrics                           Show EISV + summary
  health                            Server health (GET /health)
  tools                             List available tools (GET /v1/tools)
  call <tool> [args_json]           Invoke any tool by name
  session                           Show local session/identity state
  reset                             Clear local session
  diag                              Print config and server reachability
  help                              Show this message

Environment:
  UNITARES_URL       Base URL (default: http://localhost:8767; /mcp suffix stripped)
  UNITARES_AGENT     Stable agent name for X-Agent-Id
  UNITARES_TOKEN     Optional bearer token
  UNITARES_TIMEOUT   curl --max-time seconds (default: 15)

Examples:
  unitares diag
  unitares onboard "kenny-laptop" "interactive dev work"
  unitares update "Fixed CLI sanitization bug" 0.4 0.9
  unitares metrics
  unitares call list_agents '{}'
EOF
}

# --- dispatch ----------------------------------------------------------------

case "${1:-help}" in
    onboard|o)   shift; cmd_onboard "$@" ;;
    update|u)    shift; cmd_update "$@" ;;
    metrics|m)   shift; cmd_metrics ;;
    health|h)    shift; cmd_health ;;
    tools|t)     shift; cmd_tools ;;
    call|c)      shift; cmd_call "$@" ;;
    session|s)   shift; cmd_session ;;
    reset)       shift; cmd_reset ;;
    diag|d)      shift; cmd_diag ;;
    help|--help|-h|*) cmd_help ;;
esac
